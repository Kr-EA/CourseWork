{
  "name": "app",
  "version": "1.0.0",
  "description": "Course work",
  "license": "ISC",
  "author": "Kr-EA",
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dist": "electron-builder",
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "dev:main": "webpack --config webpack.main.config.js --watch",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js",
    "start": "electron .",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"wait-on http://localhost:3000 && npm run start\""
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "nodemon": "^3.1.11",
    "process": "^0.11.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/x-data-grid": "^8.27.3",
    "@tanstack/react-virtual": "^3.13.19",
    "better-sqlite3": "^12.6.2",
    "css-loader": "^7.1.4",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "formik": "^2.4.9",
    "react-router-dom": "^7.13.1",
    "react-virtuoso": "^4.18.1",
    "recharts": "^3.7.0",
    "style-loader": "^4.0.0",
    "ts-transformer-keys": "^0.4.4",
    "yup": "^1.7.1"
  },
  "build": {
  "appId": "com.example.myapp",
  "productName": "С.К.А.Т.",
  "directories": {
    "output": "dist"
  },
  "extraResources": [
    "python/dist/main.exe",
    "python/dist/main"
  ],
  "files": [
    "**/*",
    "!**/*.ts",
    "!*.code-workspace",
    "!LICENSE.md",
    "!package-lock.json",
    "!src/**/*",
    "!e2e/**/*",
    "!tests/**/*",
    "!*.map",
    "dist/**/*",
     "!python/env/**/*",     
    "!python/.env/**/*",     
    "!**/node_modules/**/*",
    "!python/__pycache__/**/*" 
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.icns"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icon.png"
  }
}
}
